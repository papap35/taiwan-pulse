# Taiwan Pulse - environment configuration
# Copy this file to .env.local and fill in the keys you have.
# Every source works without any key: it falls back to clearly-labeled demo
# data so the dashboard is usable immediately after `npm install && npm run dev`.

# --- 中央氣象署 (CWA) Open Data Platform ---
# Free key: https://opendata.cwa.gov.tw/ (register -> 會員中心 -> API 金鑰)
# Powers: earthquake reports (E-A0015-001), weather warnings (W-C0033-001)
CWA_API_KEY=

# --- 環境部 (MOENV, formerly EPA) Open Data ---
# Free key: https://data.moenv.gov.tw/ (會員登入 -> API 服務)
# Powers: real-time air quality (AQI) by monitoring station
MOENV_API_KEY=

# --- TDX 運輸資料流通服務 (Transport Data eXchange) ---
# Free client credentials: https://tdx.transportdata.tw/ (會員中心 -> 金鑰產生)
# Powers: national highway traffic incidents / road closures
TDX_CLIENT_ID=
TDX_CLIENT_SECRET=

# --- 水利署 防災資訊服務網 ---
# Public JSON, no key required by default. Override only if the endpoint moves.
# Powers: real-time river/flood-sensor water levels
WRA_WATER_LEVEL_URL=https://fhy.wra.gov.tw/WraApi/v1/Water/RealTimeWaterLevel

# --- 水利署 水庫即時水情 ---
# Public JSON, no key required by default. Override only if the endpoint moves.
# Powers: low-reservoir-storage events, folded into the "flood" (水利) category.
# ⚠️ This default URL is an unverified best guess (same as WRA_WATER_LEVEL_URL
# above) — see README "水利署、TDX...端點請自行核對".
WRA_RESERVOIR_URL=https://fhy.wra.gov.tw/WraApi/v1/Reservoir/RealtimeInfo

# --- News RSS (used for fire + security/crime "news bulletin" items) ---
# Comma-separated list of RSS feed URLs (e.g. wire services, official press feeds).
# A single feed = a narrow net. Add more feeds (comma-separated) to widen
# coverage — e.g. other wire services or official press-release RSS.
NEWS_RSS_FEEDS=https://feeds.feedburner.com/rsscna/domestic

# Extra keywords (comma-separated, appended to the built-in Chinese keyword list)
FIRE_EXTRA_KEYWORDS=
SECURITY_EXTRA_KEYWORDS=

# --- 行政院人事行政總處 天然災害停止上班上課 ---
# Public JSON, no key required by default. Override only if the endpoint moves.
# Powers: 停班停課 (work/school suspension) events
DGPA_SUSPENSION_URL=https://www.dgpa.gov.tw/typh/opendata/open.json

# --- 台灣電力公司 電力供需即時燈號 ---
# Public JSON, no key required by default. Override only if the endpoint moves.
# Powers: the grid-status banner (供電充裕/吃緊/警戒/準備), shown separately
# from the categorized event feed since it's a single nationwide gauge, not a
# located event.
TAIPOWER_GRID_STATUS_URL=https://service.taipower.com.tw/data/opendata/apply/file/d006001/001.json

# Poll interval (ms) the browser uses to re-fetch /api/events. Safe to lower
# now that the route itself is cached server-side (see README "自動更新機制") —
# frequent client polls mostly hit the warm cache instead of the upstream APIs.
NEXT_PUBLIC_REFRESH_MS=60000
