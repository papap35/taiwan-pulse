# Taiwan Pulse - environment configuration
# Copy this file to .env.local and fill in the keys you have.
# Every source works without any key: it falls back to clearly-labeled demo
# data so the dashboard is usable immediately after `npm install && npm run dev`.

# --- 中央氣象署 (CWA) Open Data Platform ---
# Free key: https://opendata.cwa.gov.tw/ (register -> 會員中心 -> API 金鑰)
# Powers: earthquake reports (E-A0015-001), weather warnings (W-C0033-001)
CWA_API_KEY=

# --- 環境部 (MOENV, formerly EPA) Open Data ---
# Free key: https://data.moenv.gov.tw/ (會員登入 -> API 服務)
# Powers: real-time air quality (AQI) by monitoring station
MOENV_API_KEY=

# --- TDX 運輸資料流通服務 (Transport Data eXchange) ---
# Free client credentials: https://tdx.transportdata.tw/ (會員中心 -> 金鑰產生)
# Powers: national highway traffic incidents / road closures
TDX_CLIENT_ID=
TDX_CLIENT_SECRET=

# --- 水利署 水利資料開放平台 (opendata.wra.gov.tw) ---
# Public JSON, no key required by default. Override only if the endpoint moves.
# Powers: real-time river/flood-sensor water levels
# Confirmed against a real response (2026-07-19): records only carry
# stationid/waterlevel/datetime — no alert level, name, or coordinates.
WRA_WATER_LEVEL_URL=https://opendata.wra.gov.tw/api/v2/73c4c3de-4045-4765-abeb-89f9f9cd5ff0?format=JSON

# Station reference data joined against the real-time readings above (by
# stationid == basinidentifier, confirmed by the user against a real
# response) — this is what actually provides the station name, the three
# alert-level thresholds (alertlevel1/2/3), and TWD97 coordinates (converted
# to WGS84 in lib/geo.ts) that the real-time feed itself doesn't have.
WRA_WATER_STATION_INFO_URL=https://opendata.wra.gov.tw/api/v2/c4acc691-7416-40ca-9464-292c0c00da92?format=JSON

# --- 水利署 水庫即時水情 (opendata.wra.gov.tw) ---
# Public JSON, no key required by default. Override only if the endpoint moves.
# Powers: low-reservoir-storage events, folded into the "flood" (水利) category.
# Same platform/situation as WRA_WATER_LEVEL_URL above — resource ID confirmed
# by the user, JSON field names still unconfirmed.
WRA_RESERVOIR_URL=https://opendata.wra.gov.tw/api/v2/2be9044c-6e44-4856-aad5-dd108c2e6679?format=JSON

# --- News RSS (used for fire + security/crime "news bulletin" items) ---
# Comma-separated list of RSS feed URLs (e.g. wire services, official press feeds).
# A single feed = a narrow net. Add more feeds (comma-separated) to widen
# coverage — e.g. other wire services or official press-release RSS.
NEWS_RSS_FEEDS=https://feeds.feedburner.com/rsscna/domestic

# Extra keywords (comma-separated, appended to the built-in Chinese keyword list)
FIRE_EXTRA_KEYWORDS=
SECURITY_EXTRA_KEYWORDS=

# --- 國家災害防救科技中心 (NCDR) 天然災害停止上班及上課 ---
# Public RSS/Atom feed, no key required. Override only if the endpoint moves.
# Powers: 停班停課 (work/school suspension) events, always enabled by default
# — unlike the previous guess (a DGPA JSON endpoint that turned out to never
# have existed; the only real DGPA integration found was HTML-table scraping,
# not JSON), this NCDR feed URL was confirmed by the user directly.
# AlertType=33 is the 停班停課 category.
NCDR_SUSPENSION_URL=https://alerts.ncdr.nat.gov.tw/RssAtomFeed.ashx?AlertType=33

# --- 疾病管制署 COVID-19 監測 ---
# No key required. The previous data.cdc.gov.tw CKAN search (package_search ->
# datastore_search) never actually connected in production despite four
# separate fixes (retry logic, longer timeout, maxDuration, browser
# User-Agent) — see SPEC.md T3/P1-2. Replaced entirely with these two static
# JSON files on a different domain (od.cdc.gov.tw, no CKAN indirection, no
# auth), found by the user directly in a browser and confirmed reachable.
# Powers: 疫情監測 events — per-county weekly COVID-19 ER visits (with
# week-over-week trend) plus NHI outpatient/hospitalization counts. Trade-off:
# this dropped the old multi-disease guess table (登革熱/流感/腸病毒), whose
# field names were never actually confirmed against real data anyway. Category
# reuses the "air" (空氣品質) color slot and renders as a square marker on the
# map, since all 8 categorical colors are already in use — see lib/style.ts
# CATEGORY_SHAPE.
CDC_RODS_URL=https://od.cdc.gov.tw/eic/RODS_COVID-19.json
CDC_NHI_URL=https://od.cdc.gov.tw/eic/NHI_COVID-19.json

# --- 台灣電力公司 電力供需即時燈號 ---
# Public JSON, no key required by default. Override only if the endpoint moves.
# Powers: the grid-status banner (供電充裕/吃緊/警戒/準備), shown separately
# from the categorized event feed since it's a single nationwide gauge, not a
# located event.
TAIPOWER_GRID_STATUS_URL=https://service.taipower.com.tw/data/opendata/apply/file/d006001/001.json

# Poll interval (ms) the browser uses to re-fetch /api/events. Safe to lower
# now that the route itself is cached server-side (see README "自動更新機制") —
# frequent client polls mostly hit the warm cache instead of the upstream APIs.
NEXT_PUBLIC_REFRESH_MS=60000
